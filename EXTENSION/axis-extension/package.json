{
  "name": "axis-language-support",
  "displayName": "AXIS Language Support",
  "description": "Syntax highlighting e ícone para a linguagem AXIS",
  "icon": "logo.png",
  "version": "0.2.0",
  "engines": { "vscode": "^1.50.0" },
  "categories": [ "Programming Languages" ],
  "contributes": {
    "languages": [{
      "id": "axis",
      "aliases": ["AXIS", "axis"],
      "extensions": [".axis"],
      "configuration": "./language-configuration.json",
      "icon": { "light": "./logo.png", "dark": "./logo.png" }
    }],
    "grammars": [{
      "language": "axis",
      "scopeName": "source.axis",
      "path": "./syntaxes/axis.tmLanguage.json"
    }]
  }
}