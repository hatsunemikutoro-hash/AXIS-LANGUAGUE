{
  "scopeName": "source.axis",
  "patterns": [
    {
      "name": "comment.line.dollar.axis",
      "match": "\\$.*$"
    },
    {
      "name": "string.quoted.double.axis",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.axis",
          "match": "\\\\."
        }
      ]
    },
    {
      "name": "keyword.control.axis",
      "match": "\\b(REPEAT|LOAD|EXIT|IF_EQ|IF_LT|IF_GT|JUMP|DEF|END|CALL|RETURN|MARK)\\b"
    },
    {
      "name": "keyword.operator.memory.axis",
      "match": "\\b(NEXT|PREV|SEEK|COPY)\\b"
    },
    {
      "name": "keyword.operator.arithmetic.axis",
      "match": "\\b(INC|DEC|ADD|SUB|CLEAR)\\b"
    },
    {
      "name": "support.function.io.axis",
      "match": "\\b(READ|PRINT|SAY)\\b"
    },
    {
      "name": "storage.type.axis",
      "match": "\\b(LET|VAR)\\b"
    },
    {
      "name": "variable.language.axis",
      "match": "\\bDEBUG|NODEBUG\\b"
    },
    {
      "name": "constant.numeric.axis",
      "match": "\\b[0-9]+\\b"
    },
    {
      "name": "variable.other.axis",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
    }
  ]
}